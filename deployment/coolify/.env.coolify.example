# ==============================================================================
# Sumatic Modern IoT - Coolify Deployment Environment Variables
# ==============================================================================
# Bu dosya Coolify deployment için environment variables şablonudur.
# Coolify'da her servis için bu değişkenleri girin.
# ==============================================================================

# -----------------------------------------------------------------------------
# ADMIN KULLANICI BİLGİLERİ (İlk kurulum için)
# -----------------------------------------------------------------------------
# Admin kullanıcı bilgileri - İlk deploy sonrası değiştirin!
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@sumatic.io
# Güçlü şifre (otomatik oluşturuldu - 43 karakter)
ADMIN_PASSWORD=oPf_6th1lXwOIBKQpTcVC64z8b-ZwzF8w-mTiZcQwfc

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL + TimescaleDB)
# -----------------------------------------------------------------------------
# Coolify'da PostgreSQL servisi oluşturun ve bu bilgileri kullanın
POSTGRES_USER=sumatic_user
# Güçlü şifre (otomatik oluşturuldu - 43 karakter)
POSTGRES_PASSWORD=fFRYbPqdXFzn4KwV0spAW4IUhL39b8PVXhI2gE022rE
POSTGRES_DB=sumatic_production
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# -----------------------------------------------------------------------------
# REDIS (Rate Limiting ve Caching)
# -----------------------------------------------------------------------------
# Güçlü şifre (otomatik oluşturuldu - 43 karakter)
REDIS_PASSWORD=bEYDCdeQRh204E_OkjxxC_Oze_8XHueljdxR8pXUFIY
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# -----------------------------------------------------------------------------
# MQTT Configuration (SSH Tunnel üzerinden)
# -----------------------------------------------------------------------------
# Not: MQTT bağlantısı SSH tunnel üzerinden yapılır
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_USERNAME=sumatic-backend-prod
# Güçlü şifre (otomatik oluşturuldu - 43 karakter)
MQTT_PASSWORD=1CsDlPIgPPXA0y2FuOIRLJHytrjZdxxFemQGmd42wM0
MQTT_CLIENT_ID=sumatic-backend-prod
MQTT_TOPIC_ALLDATAS=Alldatas
MQTT_TOPIC_COMMANDS=Commands

# -----------------------------------------------------------------------------
# SSH Tunnel Configuration
# -----------------------------------------------------------------------------
# SSH tunnel ile remote MQTT sunucusuna bağlanılır
SSH_ENABLED=true
SSH_HOST=31.58.236.246
SSH_PORT=22
SSH_USER=sumatic-tunnel
# SSH key Coolify secrets olarak eklenmeli
SSH_KEY_PATH=/app/.ssh/sumatic_tunnel_key
SSH_REMOTE_MQTT_HOST=127.0.0.1
SSH_REMOTE_MQTT_PORT=1883
SSH_LOCAL_MQTT_HOST=127.0.0.1
SSH_LOCAL_MQTT_PORT=1883
SSH_KEEPALIVE=30

# -----------------------------------------------------------------------------
# JWT Authentication - KRİTİK GÜVENLİK
# -----------------------------------------------------------------------------
# Güçlü secret key (otomatik oluşturuldu - 64 karakter hex)
JWT_SECRET_KEY=037f148dd3367297c31571a0483c6d7e0a9f00e1413b5c87e226a3ef3dba91e5
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# Production domain'inizi buraya ekleyin
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
RATE_LIMIT_PER_MINUTE=100

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Sumatic Modern IoT
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1
TIMEZONE=Europe/Istanbul

# -----------------------------------------------------------------------------
# Device Monitoring
# -----------------------------------------------------------------------------
DEVICE_OFFLINE_THRESHOLD_SECONDS=600
DEVICE_RETRY_INTERVAL_SECONDS=60
DEVICE_MAX_RETRIES=5
SNAPSHOT_INTERVAL_MINUTES=10
SPIKE_STREAK_THRESHOLD=5
SPIKE_WINDOW_SIZE=5

# -----------------------------------------------------------------------------
# Frontend Environment Variables
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com
NODE_ENV=production
