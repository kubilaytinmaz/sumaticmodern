# ────────────────────────────────────────────────────────────────
# Sumatic Modern IoT - Environment Variables
# ────────────────────────────────────────────────────────────────
# Copy this file to .env and update with your actual values
# Never commit .env file to version control!
# ────────────────────────────────────────────────────────────────

# ─── Application ───────────────────────────────────────────────
APP_NAME="Sumatic Modern IoT"
APP_VERSION="1.0.0"
DEBUG=false
API_V1_PREFIX="/api/v1"

# ─── Database (PostgreSQL + TimescaleDB) ───────────────────────
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL="postgresql+asyncpg://sumatic:sumatic123@localhost:5432/sumatic_db"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ─────────────────────────────────────────────────────
# Format: redis://[username:password@]host:port/database
REDIS_URL="redis://localhost:6379/0"

# ─── MQTT Broker ───────────────────────────────────────────────
MQTT_BROKER_HOST="localhost"
MQTT_BROKER_PORT=1883
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_CLIENT_ID="sumatic-backend"
MQTT_TOPIC_ALLDATAS="Alldatas"
MQTT_TOPIC_COMMANDS="Commands"

# ─── JWT Authentication ────────────────────────────────────────
# IMPORTANT: Change this to a secure random key in production!
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY="change-this-to-a-secure-random-key-in-production-use-openssl-rand-hex-32"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Security ──────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
RATE_LIMIT_PER_MINUTE=100

# ─── Timezone ──────────────────────────────────────────────────
TIMEZONE="Europe/Istanbul"

# ─── Device Monitoring ─────────────────────────────────────────
# Time in seconds before a device is considered offline
DEVICE_OFFLINE_THRESHOLD_SECONDS=600
# Retry interval in seconds for offline devices
DEVICE_RETRY_INTERVAL_SECONDS=60
# Maximum number of retries before marking device as failed
DEVICE_MAX_RETRIES=5

# ─── Snapshot Configuration ────────────────────────────────────
# Interval in minutes for creating data snapshots
SNAPSHOT_INTERVAL_MINUTES=10

# ─── Spike Filter ──────────────────────────────────────────────
# Number of consecutive spikes before triggering alert
SPIKE_STREAK_THRESHOLD=5
# Window size for spike detection
SPIKE_WINDOW_SIZE=5

# ─── Tuya Cloud (Smart Plug) ───────────────────────────────────
# Get from Tuya IoT Platform: https://iot.tuya.com/
TUYA_ACCESS_ID=""
TUYA_ACCESS_SECRET=""
TUYA_API_REGION="eu"
TUYA_POLL_INTERVAL_SECONDS=30

# ────────────────────────────────────────────────────────────────
# Production Deployment Notes:
# ────────────────────────────────────────────────────────────────
# 1. Generate a secure JWT_SECRET_KEY:
#    $ openssl rand -hex 32
#
# 2. Use strong database credentials
#
# 3. Enable SSL/TLS for PostgreSQL connection:
#    DATABASE_URL="postgresql+asyncpg://user:pass@host:5432/db?ssl=require"
#
# 4. Use Redis password:
#    REDIS_URL="redis://:password@localhost:6379/0"
#
# 5. Configure MQTT with TLS:
#    MQTT_BROKER_PORT=8883
#    MQTT_TLS_ENABLED=true
#
# 6. Set appropriate CORS_ORIGINS for your frontend domain
#
# 7. Set DEBUG=false in production
# ────────────────────────────────────────────────────────────────
