# =============================================================================
# Sumatic Modern IoT - Backend .dockerignore
# =============================================================================

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml

# Environment files
.env
.env.local
.env.*.local

# Documentation
docs/
*.md
!README.md

# Git
.git/
.gitignore

# CI/CD
.github/
.gitlab-ci.yml

# Logs
*.log
logs/

# Database (exclude from Docker build)
*.db
*.sqlite
*.sqlite3

# Exception: Include sumatic_modern.db for one-time migration
!sumatic_modern.db

# Temporary files
tmp/
temp/
*.tmp

# Build artifacts
build/
dist/
*.egg-info/

# Alembic (we need these)
!alembic/
!alembic.ini
