# ==============================================================================
# Sumatic Modern IoT - Production Environment Configuration
# ==============================================================================
# ⚠️ KRİTİK GÜVENLİK UYARISI: Bu dosya production için örnektir.
# Production'a deploy etmeden önce aşağıdaki adımları takip edin:
#
# 1. Tüm CHANGE_ME değerlerini güvenli random değerlerle değiştirin
# 2. JWT_SECRET_KEY için: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 3. SSH key-based authentication kullanın (password yerine)
# 4. PostgreSQL kullanın (SQLite production için uygun değildir)
# 5. CORS_ORIGINS'i sadece production domain'lerle sınırlayın
# 6. DEBUG=false olduğundan emin olun
# ==============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Sumatic Modern IoT
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Database (PostgreSQL - Production için zorunlu)
# -----------------------------------------------------------------------------
# SQLite production için uygun değildir. PostgreSQL kullanın:
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://sumatic_user:CHANGE_ME_GENERATE_STRONG_PASSWORD@localhost:5432/sumatic_production
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# PostgreSQL kullanıcı oluşturma komutu:
# CREATE USER sumatic_user WITH PASSWORD 'strong_password_here';
# CREATE DATABASE sumatic_production OWNER sumatic_user;
# GRANT ALL PRIVILEGES ON DATABASE sumatic_production TO sumatic_user;

# -----------------------------------------------------------------------------
# Redis (Production için önerilir - rate limiting için)
# -----------------------------------------------------------------------------
# Rate limiting için Redis kullanmak, dağıtık sistemlerde daha iyi performans sağlar
REDIS_URL=redis://localhost:6379/0
# Redis şifreli: redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0

# -----------------------------------------------------------------------------
# MQTT Configuration (SSH Tunnel üzerinden)
# -----------------------------------------------------------------------------
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_USERNAME=sumatic-backend-prod
MQTT_PASSWORD=CHANGE_ME_GENERATE_STRONG_MQTT_PASSWORD
MQTT_CLIENT_ID=sumatic-backend-prod
MQTT_TOPIC_ALLDATAS=Alldatas
MQTT_TOPIC_COMMANDS=Commands

# MQTT TLS/SSL Configuration
# ⚠️ GÜVENLİK: Production'da TLS kullanın (MQTT_TLS_ENABLED=true)
# TLS sertifikaları oluşturmak için: deployment/generate_mqtt_certs.sh
MQTT_TLS_ENABLED=true
MQTT_TLS_PORT=8883
# CA certificate path (server certificate verification)
MQTT_TLS_CA_CERT=/path/to/mqtt/certs/ca.crt
# Client certificate path (mTLS - mutual TLS authentication)
MQTT_TLS_CLIENT_CERT=/path/to/mqtt/certs/client.crt
MQTT_TLS_CLIENT_KEY=/path/to/mqtt/certs/client.key
# Client certificate zorunlu mu (mTLS için true)
MQTT_TLS_REQUIRE_CERT=true
# Sadece test için self-signed sertifikalarda false yapın
MQTT_TLS_INSECURE=false

# -----------------------------------------------------------------------------
# Data Encryption at Rest
# -----------------------------------------------------------------------------
# ⚠️ GÜVENLİK: Production'da mutlaka şifreleme anahtarı kullanın
# Base64-encoded 32-byte (256-bit) encryption key for sensitive data
# Bu anahtar, veritabanındaki hassas verileri şifrelemek için kullanılır
# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# IMPORTANT: Bu anahtarı güvenli bir yerde saklayın ve asla versiyon kontrolüne commit etmeyin!
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_python_-c_"import_os,_base64;_print(base64.b64encode(os.urandom(32)).decode())"

# -----------------------------------------------------------------------------
# SSH Tunnel Configuration
# -----------------------------------------------------------------------------
# ⚠️ GÜVENLİK: SSH_PASSWORD yerine SSH_KEY_PATH kullanın
# SSH key generation: ssh-keygen -t ed25519 -f ~/.ssh/sumatic_tunnel_key
SSH_ENABLED=true
SSH_HOST=31.58.236.246
SSH_PORT=22
SSH_USER=sumatic-tunnel
# SSH_PASSWORD=  # Production'da boş bırakın, key-based auth kullanın
SSH_KEY_PATH=/path/to/ssh/private/key
SSH_REMOTE_MQTT_HOST=127.0.0.1
SSH_REMOTE_MQTT_PORT=1883
SSH_LOCAL_MQTT_HOST=127.0.0.1
SSH_LOCAL_MQTT_PORT=1883
SSH_KEEPALIVE=30

# SSH tunnel kullanıcı oluşturma (remote sunucuda):
# sudo useradd -m -s /bin/bash sumatic-tunnel
# sudo usermod -aG dialout sumatic-tunnel  # Eğer gerekliyse
# SSH key'i ~/.ssh/authorized_keys'e ekleyin

# -----------------------------------------------------------------------------
# JWT Authentication - KRİTİK GÜVENLİK
# -----------------------------------------------------------------------------
# ⚠️ GÜVENLİK UYARISI: JWT_SECRET_KEY mutlaka güçlü random string olmalı
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Minimum 32 karakter, rastgele, tahmin edilemez olmalı
JWT_SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_KEY_MIN_32_CHARS_HERE
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# ⚠️ CORS_ORIGINS sadece production domain'lerini içermeli
# Virgülle ayrılmış liste, boşluk yok
CORS_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=100

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TIMEZONE=Europe/Istanbul

# -----------------------------------------------------------------------------
# Device Monitoring
# -----------------------------------------------------------------------------
DEVICE_OFFLINE_THRESHOLD_SECONDS=600  # 10 dakika
DEVICE_RETRY_INTERVAL_SECONDS=60
DEVICE_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# Snapshot Settings
# -----------------------------------------------------------------------------
SNAPSHOT_INTERVAL_MINUTES=10

# -----------------------------------------------------------------------------
# Spike Filter Settings
# -----------------------------------------------------------------------------
SPIKE_STREAK_THRESHOLD=5
SPIKE_WINDOW_SIZE=5

# ==============================================================================
# DEPLOYMENT ÖNCESİ KONTROL LİSTESİ
# ==============================================================================
#
# [ ] JWT_SECRET_KEY güçlü random key ile değiştirildi
# [ ] SSH_PASSWORD kaldırıldı, SSH_KEY_PATH kullanılıyor
# [ ] SSH key oluşturuldu ve remote sunucuya eklendi
# [ ] MQTT username/password değiştirildi
# [ ] MQTT TLS sertifikaları oluşturuldu (deployment/generate_mqtt_certs.sh)
# [ ] MQTT_TLS_ENABLED=true ayarlandı
# [ ] MQTT broker TLS yapılandırması tamamlandı
# [ ] PostgreSQL kullanıma hazır (user, database, permissions)
# [ ] CORS_ORISINS sadece production domain'lerini içeriyor
# [ ] DEBUG=false
# [ ] Redis çalışıyor (opsiyonel ama önerilir)
# [ ] SSL sertifikası kuruldu (HTTPS)
# [ ] Firewall kuralları yapılandırıldı
# [ ] Backup planı test edildi
# [ ] Log monitoring aktif
# ==============================================================================
