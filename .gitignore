# ===== CRITICAL: Coolify Deployment Secrets =====
# SSH private keys
deployment/coolify/sumatic_tunnel_key
deployment/coolify/*_key
deployment/coolify/*_key.pub
# Credentials files with real secrets
deployment/coolify/CREDENTIALS.md

# Production secrets script output
backend/setup_production_secrets.py.output

# ===== CRITICAL: MQTT Security Files =====
# MQTT certificates and keys
mqtt-broker/certs/*.key
mqtt-broker/certs/*.crt
mqtt-broker/certs/ca.crt
mqtt-broker/certs/server.crt
mqtt-broker/certs/server.key
mqtt-broker/certs/client.crt
mqtt-broker/certs/client.key
# Keep certificate generation scripts, ignore generated certs
# mqtt-broker/certs/  # Entire certs directory

# MQTT password file
mqtt-broker/passwd
mqtt-broker/.backend_credentials
mqtt-broker/.device_credentials

# MQTT configuration backups
mqtt-broker/*.pre-migration
mqtt-broker/*.backup

# Production environment files
backend/.env.production.direct_mqtt
