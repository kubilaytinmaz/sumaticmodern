# ===== CRITICAL: Environment files =====
# NEVER commit actual .env files with credentials
backend/.env
backend/.env.production
backend/.env.production.backup
backend/.env.local
backend/.env.staging
.env.production
.env.production.backup
.env.local
.env.staging
# .env.example and .env.production.example are safe to commit (no real credentials)

